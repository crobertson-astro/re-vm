{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "local_bash",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "bash_command": {
      "description": "Bash command to execute locally.",
      "title": "Bash Command",
      "type": "string"
    },
    "env": {
      "description": "Optional environment variables.",
      "title": "Env",
      "type": "object",
      "default": {},
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "integer" },
          { "type": "number" },
          { "type": "boolean" },
          { "type": "null" }
        ]
      }
    },
    "cwd": {
      "description": "Optional working directory for the command.",
      "title": "Cwd",
      "default": null,
      "anyOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "append_env": {
      "description": "Append env values to the worker environment.",
      "title": "Append Env",
      "type": "boolean",
      "default": false
    },
    "pool": {
      "description": "Optional pool for the bash task.",
      "title": "Pool",
      "default": null,
      "anyOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "blueprint": {
      "type": "string",
      "const": "local_bash",
      "description": "The blueprint template to use"
    },
    "version": {
      "type": "integer",
      "const": 1,
      "description": "The blueprint version"
    }
  },
  "required": ["blueprint", "version", "bash_command"]
}
